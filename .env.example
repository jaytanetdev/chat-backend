# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (PostgreSQL)
# For local development with docker-compose:
# DB_HOST=localhost
# DB_PORT=5432
# DB_USERNAME=postgres
# DB_PASSWORD=postgres
# DB_DATABASE=chat_db

# For production/external database:
DB_HOST=76.13.211.14
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=123123@Jay
DB_DATABASE=postgres

# JWT Configuration
JWT_SECRET=JWT_SUPER_SECRET_KEY
JWT_EXPIRES_IN=7d

# CORS Configuration (comma-separated origins)
CORS_ORIGIN=http://localhost:3000,http://localhost:9000

# LINE Platform Configuration
# Get from: https://developers.line.biz/console/
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token

# Facebook Messenger Configuration
# Get from: https://developers.facebook.com/apps/
FB_APP_SECRET=your_facebook_app_secret
FB_PAGE_ACCESS_TOKEN=your_facebook_page_access_token
FB_VERIFY_TOKEN=your_facebook_verify_token

# Instagram Configuration
# Uses same credentials as Facebook
IG_VERIFY_TOKEN=your_instagram_verify_token

# Shopee Open Platform Configuration
# Get from: https://open.shopee.com/
SHOPEE_PARTNER_ID=your_shopee_partner_id
SHOPEE_PARTNER_KEY=your_shopee_partner_key
SHOPEE_REDIRECT_URL=http://localhost:9000/shopee/callback

# Lazada Open Platform Configuration
# Get from: https://open.lazada.com/
LAZADA_APP_KEY=your_lazada_app_key
LAZADA_APP_SECRET=your_lazada_app_secret
LAZADA_REDIRECT_URL=http://localhost:9000/lazada/callback

# Redis Configuration (optional - for caching/polling locks)
REDIS_URL=redis://localhost:6379

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret